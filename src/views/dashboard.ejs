<!DOCTYPE html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - BrAPI</title>
    <link rel="stylesheet" href="/dashboard/style.css">
</head>

<body>

    <% if (user.force_password_reset) { %>

    <div class="force-reset">
        <div>
            ⚠️ Por segurança, você precisa trocar sua senha inicial.
        </div>

        <form method="POST" action="/auth/reset-password-inline">
            <input name="password" type="password" placeholder="Nova senha" required />
            <button>Atualizar</button>
        </form>
    </div>

    <% } %>

    <header>
        <div class="left" onclick="window.location.href='/'">
            <img src="/index/apiLogo.png">
            <span>BrApi</span>
        </div>

        <div class="center">
            <a href="/docs" class="nav-item">Docs</a>
            <a href="/dashboard" class="nav-item active">Dashboard</a>
        </div>

        <div class="right">
            <span class="user">
                <%= user.username %>
            </span>

            <form method="POST" action="/auth/logout">
                <button>Sair</button>
            </form>

            <div class="hamburger" id="hamburger">
                <span></span>
                <span></span>
                <span></span>
            </div>
        </div>
    </header>

    <div class="mobile-menu" id="mobileMenu">
        <a href="/docs" class="nav-item">Docs</a>
        <a href="/dashboard" class="nav-item">Dashboard</a>
    </div>
    <main class="dashboard">

        <% if (user && user.role==="admin" ) { %>
            <div class="admin-alert">
                <span>⚠️ Você tem privilégios de administrador</span>
                <a href="/admin" class="admin-btn">Ir para painel</a>
            </div>
            <% } %>


                <!-- CARDS -->
                <div class="cards">

                    <div class="card">
                        <h3>API Key</h3>
                        <p class="mono">
                            <%= user.api_key %>
                        </p>
                    </div>

                    <div class="card">
                        <h3>Limite</h3>
                        <p>
                            <%= user.rate_limit %> req/hora
                        </p>
                    </div>

                    <div class="card">
                        <h3>Status</h3>
                        <p class="status ok">Ativo</p>
                    </div>

                </div>

                <!-- USO -->
                <div class="usage">
                    <h2>Uso da API</h2>

                    <div class="progress">
                        <div class="bar" style="width: <%= usagePercent %>%"></div>
                    </div>

                    <p>
                        <%= usagePercent.toFixed(0) %>% do limite usado
                            (<%= user.usage_count %> / <%= user.rate_limit %>)
                    </p>
                </div>

    </main>

</body>

</html>